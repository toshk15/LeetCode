class Solution:
    def maxSubsequence(self, nums: List[int], k: int) -> List[int]:
        heap=[]
        for i,num in enumerate(nums):
            heapq.heappush(heap,(num,i))
            if len(heap)>k:
                heapq.heappop(heap)
        heap.sort(key=lambda x:x[1])
        return [i for i,j in heap]
            
